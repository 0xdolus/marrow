<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chromeBg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f0f0f">

    <!-- MAIN CONTENT AREA -->
    <LinearLayout
        android:id="@+id/contentArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- TOP PANE -->
        <LinearLayout
            android:id="@+id/topPaneContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Top pane title bar (split mode only) -->
            <TextView
                android:id="@+id/topTitleBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#0f0f0f"
                android:textSize="11sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Thread mode badge row -->
            <LinearLayout
                android:id="@+id/topModeRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp"
                android:gravity="center_vertical"
                android:background="#0f0f0f">

                <TextView
                    android:id="@+id/threadBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/thread_mode"
                    android:textColor="#0f0f0f"
                    android:textSize="11sp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_thread_badge" />

                <TextView
                    android:id="@+id/fullBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/full_mode"
                    android:textColor="#f0ead6"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_full_btn" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/pipDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_pip"
                    android:layout_marginEnd="4dp" />

            </LinearLayout>

            <!-- JS banner -->
            <LinearLayout
                android:id="@+id/jsBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:visibility="gone"
                android:background="@drawable/bg_js_banner">

                <TextView
                    android:id="@+id/jsBannerDomain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#f0ead6"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/jsAllowBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/js_allow"
                        android:textColor="#f0ead6"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/bg_js_btn" />

                    <TextView
                        android:id="@+id/jsAllowOnceBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/js_allow_once"
                        android:textColor="#f0ead6"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:padding="6dp"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_js_btn" />

                    <TextView
                        android:id="@+id/jsKeepOffBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/js_keep_off"
                        android:textColor="#f0ead6"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:padding="6dp"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_js_btn" />

                </LinearLayout>
            </LinearLayout>

            <!-- CF banner -->
            <LinearLayout
                android:id="@+id/cfBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:visibility="gone"
                android:background="@drawable/bg_js_banner">

                <TextView
                    android:id="@+id/cfBannerDomain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#f0ead6"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/cfAllowBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/cf_allow"
                        android:textColor="#f0ead6"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/bg_js_btn" />

                    <TextView
                        android:id="@+id/cfDismissBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/cf_dismiss"
                        android:textColor="#f0ead6"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:padding="6dp"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_js_btn" />

                </LinearLayout>
            </LinearLayout>

            <!-- Memory banner -->
            <TextView
                android:id="@+id/memBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#f0ead6"
                android:textSize="11sp"
                android:padding="4dp"
                android:background="#8b0000"
                android:visibility="gone" />

            <!-- Top WebView — wrapped in FrameLayout for dim overlay -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <WebView
                    android:id="@+id/webView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Dim overlay for inactive top pane -->
                <View
                    android:id="@+id/splitDimOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#26000000"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

        <!-- SPLIT DIVIDER (draggable) -->
        <View
            android:id="@+id/splitDivider"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="#5a9a5a"
            android:visibility="gone" />

        <!-- BOTTOM PANE -->
        <LinearLayout
            android:id="@+id/bottomPaneContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Bottom pane title bar -->
            <TextView
                android:id="@+id/bottomTitleBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#0f0f0f"
                android:textSize="11sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:ellipsize="end"
                android:background="#1a1a1a"
                android:visibility="gone" />

            <WebView
                android:id="@+id/splitWebView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </LinearLayout>

    <!-- BOTTOM CHROME -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp"
        android:paddingTop="4dp">

        <!-- Loading bar -->
        <ProgressBar
            android:id="@+id/loadingBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="#8ab8d8"
            android:progressBackgroundTint="#1f1f1f"
            android:visibility="invisible" />

        <!-- Tab strip -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:id="@+id/tabStripInner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

        <!-- URL row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tabCountBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#0f0f0f"
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/bg_tab_pill_active" />

            <!-- Fix #4: pane indicator dot -->
            <View
                android:id="@+id/paneIndicator"
                android:layout_width="6dp"
                android:layout_height="24dp"
                android:layout_marginStart="6dp"
                android:background="#5a9a5a"
                android:visibility="gone" />

            <EditText
                android:id="@+id/urlInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:hint="@string/url_hint"
                android:textColorHint="#555"
                android:textColor="#c8bfaf"
                android:textSize="12sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:background="@drawable/bg_url_bar"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:maxLines="1"
                android:selectAllOnFocus="true" />

            <TextView
                android:id="@+id/imgSearchBtn"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="@string/img_search"
                android:textColor="#c8bfaf"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_tab_pill" />

            <!-- Split button -->
            <TextView
                android:id="@+id/splitBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⊟"
                android:textColor="#c8bfaf"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_tab_pill" />

        </LinearLayout>

        <!-- Exit split row -->
        <TextView
            android:id="@+id/exitSplitBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/exit_split"
            android:textColor="#c8bfaf"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_tab_pill"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Tab overlay -->
    <FrameLayout
        android:id="@+id/tabOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0f0f0f"
        android:visibility="gone" />

</LinearLayout>

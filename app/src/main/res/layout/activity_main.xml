<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/threadBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="10dp"
            android:text="@string/thread_mode"
            android:textColor="@color/accent_green"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_thread_badge"
            android:visibility="visible" />

        <Button
            android:id="@+id/fullPageBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="10dp"
            android:text="@string/full_page"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_full_btn"
            android:stateListAnimator="@null" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/chrome_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/urlText"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/loading"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_url_bar"
            android:ellipsize="end"
            android:singleLine="true" />

    </LinearLayout>

</LinearLayout>
